# ── Backend ───────────────────────────────────────────────
DATABASE_URL=sqlite:///./data/app.db
VAULT_PATH=../vault

# ── LLM ───────────────────────────────────────────────────
OPENAI_API_KEY=your_key_here
# Model to use for proposal generation (e.g. gpt-4o, gpt-4-turbo)
LLM_MODEL=gpt-4o

# ── GitHub connector ──────────────────────────────────────
GITHUB_TOKEN=

# ── Gmail connector ───────────────────────────────────────
# OAuth credentials from Google Cloud Console (Desktop app or Web app type).
# GMAIL_REDIRECT_URI defaults to http://localhost:7400/auth/gmail/callback —
# register that exact URL under "Authorized redirect URIs" in Google Cloud Console.
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=

# ── Slack connector ───────────────────────────────────────
# User OAuth token (xoxp-...) — requires search:read, channels:history,
# groups:history, im:history, mpim:history, users:read scopes.
SLACK_USER_TOKEN=
# Optional: comma-separated keywords to search for (mirrors Slack keyword alerts)
SLACK_KEYWORDS=

# ── Canvas connector ──────────────────────────────────────
CANVAS_API_KEY=
CANVAS_BASE_URL=
