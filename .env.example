# ── Backend ───────────────────────────────────────────────
DATABASE_URL=sqlite:///./data/app.db
VAULT_PATH=./vault

# ── LLM ───────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_key_here

# ── GitHub connector ──────────────────────────────────────
GITHUB_TOKEN=

# ── Gmail connector ───────────────────────────────────────
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=

# ── Slack connector ───────────────────────────────────────
# User OAuth token (xoxp-...) — requires search:read, channels:history,
# groups:history, im:history, mpim:history, users:read scopes.
SLACK_USER_TOKEN=
# Optional: comma-separated keywords to search for (mirrors Slack keyword alerts)
SLACK_KEYWORDS=

# ── Canvas connector ──────────────────────────────────────
CANVAS_API_KEY=
CANVAS_BASE_URL=
